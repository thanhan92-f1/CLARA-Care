# =====================================================
# CLARA - Local Development Environment (P0)
# =====================================================
ENV=development
LOG_LEVEL=INFO
TZ=Asia/Ho_Chi_Minh

# -----------------------------
# API / Web / ML Runtime
# -----------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
ML_SERVICE_URL=http://localhost:8110
ML_SERVICE_TIMEOUT_SECONDS=60
WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=/api/v1
ML_HOST=0.0.0.0
ML_PORT=8010
WEB_PORT=3000
APP_API_PORT=8100
APP_WEB_PORT=3100
APP_ML_PORT=8110
APP_SEARXNG_PORT=8888

# -----------------------------
# Auth
# -----------------------------
JWT_SECRET_KEY=change_me_super_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=43200
AUTH_AUTO_PROVISION_USERS=true
AUTH_BOOTSTRAP_ADMIN_ENABLED=true
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
AUTH_BOOTSTRAP_ADMIN_PASSWORD=wrongpass
AUTH_BOOTSTRAP_ADMIN_FORCE_RESET_PASSWORD=true
AUTH_REQUIRE_EMAIL_VERIFICATION=false
MEDICAL_DISCLAIMER_VERSION=2026-04-v1

# -----------------------------
# Compose-exposed ports (override if conflict)
# -----------------------------
POSTGRES_PORT=5432
REDIS_PORT=6379
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091
ELASTIC_PORT=9200
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------
# PostgreSQL
# -----------------------------
POSTGRES_USER=clara
POSTGRES_PASSWORD=clara_dev_password
POSTGRES_DB=clara
POSTGRES_HOST=localhost
DATABASE_URL=postgresql+psycopg://clara:clara_dev_password@localhost:5432/clara

# -----------------------------
# Redis
# -----------------------------
REDIS_HOST=localhost
REDIS_URL=redis://localhost:6379/0

# -----------------------------
# Milvus / Vector DB
# -----------------------------
MILVUS_HOST=localhost

# -----------------------------
# Elasticsearch
# -----------------------------
ELASTICSEARCH_URL=http://localhost:9200

# -----------------------------
# Neo4j
# -----------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=clara_dev_password
NEO4J_AUTH=neo4j/clara_dev_password

# -----------------------------
# MinIO (Milvus dependency)
# -----------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9000

# -----------------------------
# External API keys / credentials
# -----------------------------
OPENAI_API_KEY=your_openai_api_key
NCBI_API_KEY=your_ncbi_api_key
WHO_ICD11_CLIENT_ID=your_who_client_id
WHO_ICD11_CLIENT_SECRET=your_who_client_secret
OPENFDA_API_KEY=your_openfda_api_key_optional
CLINICALTRIALS_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.yescale.vip/v1
DEEPSEEK_MODEL=deepseek-v3.2
DEEPSEEK_TIMEOUT_SECONDS=30
EMBEDDING_API_KEY=
YESCALE_API_KEY=
EMBEDDING_BASE_URL=https://api.yescale.io/v1
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_TIMEOUT_SECONDS=6
RAG_EXTERNAL_CONNECTORS_ENABLED=true
RAG_EXTERNAL_TIMEOUT_SECONDS=4
SEARXNG_BASE_URL=
SEARXNG_PUBLIC_BASE_URL=http://127.0.0.1:8888/
SEARXNG_TIMEOUT_SECONDS=3
EXTERNAL_DDI_ENABLED=true
EXTERNAL_DDI_TIMEOUT_SECONDS=1.5
# OCR provider key nên đặt ở tgc-transhub.
# CLARA chỉ gọi OCR nội bộ qua endpoint của tgc-transhub.
TGC_OCR_BASE_URL=http://host.docker.internal:8080
TGC_OCR_ENDPOINTS=/api/ocr,/api/extract,/ocr
TGC_OCR_TIMEOUT_SECONDS=45
TGC_OCR_API_KEY=

# -----------------------------
# RAG / Model defaults
# -----------------------------
DEFAULT_EMBEDDING_MODEL=bge-m3
DEFAULT_ROUTER_MODEL=qwen2.5-0.5b-instruct
DEFAULT_SYNTHESIS_MODEL=qwen2.5-72b-instruct

# -----------------------------
# Rate limits / caching
# -----------------------------
GLOBAL_RATE_LIMIT_PER_MIN=120
RATE_LIMIT_WINDOW_SECONDS=60
PUBMED_RATE_LIMIT_PER_SEC=10
CACHE_TTL_GENERAL_SEC=86400
CACHE_TTL_DRUG_SEC=21600
